# P3 â€” checkpoint-write
# ML checkpoint save pattern. Surfaces S3 Files writeâ†’S3 sync visibility.
# Run via: fio --output-format=json+ --output=$OUT p3_checkpoint_write.fio
# Required env: FIO_DIR, FIO_DIRECT

[global]
directory=${FIO_DIR}
direct=${FIO_DIRECT}
ioengine=libaio
group_reporting=1
runtime=60
ramp_time=30
time_based=1

[checkpoint-write]
rw=write
bs=4M
size=1G
iodepth=4
numjobs=1
fsync_on_close=1
end_fsync=1
