# P2 — random-read-4k
# DB-like random small read. H1 core verification ("1ms 이하" claim).
# Run via: fio --output-format=json+ --output=$OUT p2_random_read_4k.fio
# Required env: FIO_DIR, FIO_DIRECT

[global]
directory=${FIO_DIR}
direct=${FIO_DIRECT}
ioengine=libaio
group_reporting=1
runtime=60
ramp_time=30
time_based=1

[random-read-4k]
rw=randread
bs=4K
size=64M
iodepth=64
numjobs=2
filename_format=$jobnum/$filenum
nrfiles=64
